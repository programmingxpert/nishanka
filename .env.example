# ==========================================
# Nishanka Discord Bot - Environment Config (Example)
# ==========================================

# Discord Bot Token (from https://discord.com/developers/applications)
TOKEN=your_discord_bot_token_here

# Bot Application/Client ID (needed for slash command registration)
CLIENT_ID=your_client_id_here

# Guild ID for testing slash commands in a single server (optional)
GUILD_ID=your_testing_guild_id_here

# MongoDB Connection URI
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Prefix for message-based (non-slash) commands
PREFIX=-

# ==========================================
# Lavalink Configuration
# Nodes for streaming audio
# ==========================================
# Node 1
LAVALINK_HOST=your_lavalink_host_here
LAVALINK_PORT=443
LAVALINK_PASSWORD=your_lavalink_password_here
LAVALINK_SECURE=true

# Node 2 (Backup)
LAVALINK_HOST_2=your_lavalink_host_2_here
LAVALINK_PORT_2=443
LAVALINK_PASSWORD_2=your_lavalink_password_2_here
LAVALINK_SECURE_2=true

# Node 3 (Backup)
LAVALINK_HOST_3=your_lavalink_host_3_here
LAVALINK_PORT_3=443
LAVALINK_PASSWORD_3=your_lavalink_password_3_here
LAVALINK_SECURE_3=true

BOT_API_TOKEN=your_bot_api_token_here

# Dashboard OAuth2 Credentials (from Discord Developer Portal -> OAuth2)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:4000/auth/callback
FRONTEND_URL=http://localhost:5173

# Razorpay Configuration (for domestic payments/donations)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# PayPal Configuration (for international payments/donations)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# Top.gg Vote Webhook Authorization
TOPGG_WEBHOOK_AUTH=your_topgg_webhook_secret_here
